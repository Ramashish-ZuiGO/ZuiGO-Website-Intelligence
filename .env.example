APP_ENV=development
LOG_LEVEL=INFO
POSTGRES_USER=website_intelligence
POSTGRES_PASSWORD=replace_with_a_secure_local_password
POSTGRES_DB=website_intelligence
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
BACKEND_CORS_ORIGINS=http://localhost:3000
AI_PROVIDER=disabled
AI_MODEL=not-configured
AI_BASE_URL=http://host.docker.internal:11434
AI_TIMEOUT_SECONDS=120
BROWSER_LAUNCH_TIMEOUT_MS=20000
NAVIGATION_TIMEOUT_MS=45000
DOM_READINESS_TIMEOUT_MS=15000
PAGE_STABILIZATION_MS=2000
EVIDENCE_COLLECTION_TIMEOUT_MS=20000
LIGHTHOUSE_TIMEOUT_SECONDS=120
ANALYSIS_JOB_TIMEOUT_SECONDS=300
ANALYSIS_MAX_ATTEMPTS=2
ANALYSIS_RETRY_BACKOFF_SECONDS=1
W3C_VALIDATION_ENABLED=true
W3C_VALIDATION_ENDPOINT=https://validator.w3.org/nu/?out=json
W3C_TIMEOUT_SECONDS=20
POLICY_PAGE_TIMEOUT_SECONDS=15
DIAGNOSTIC_MAX_RESOURCES=20
DIAGNOSTIC_EVIDENCE_LIMIT=20
RESPONSIVE_VIEWPORTS=mobile_portrait:390x844,mobile_landscape:844x390,tablet:768x1024,laptop:1366x768,desktop:1920x1080
